# Terraform state files — never commit these
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform plan files — contain sensitive data
tfplan
*.tfplan

# Terraform working directories
**/.terraform/
.terraform.lock.hcl

# Variable files with secrets
*.tfvars.json
# Exclude all tfvars EXCEPT committed baseline files
# *.tfvars  ← intentionally NOT ignored (baseline vars are committed without secrets)

# Crash log files
crash.log
crash.*.log

# Sensitive override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config
.terraformrc
terraform.rc

# macOS
.DS_Store

# Editor directories
.idea/
.vscode/
*.swp
*.swo
